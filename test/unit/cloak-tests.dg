%% dgdebug -u cloak-tests.dg cloak.dg unit.dg stdlib.dg

(set up $)
    (move player to #in #foyer)
	(now) (#cloak is #wornby #player)
	(now) ~(hook point awarded)
	(now) ~(message has been trampled)
	(current score $Score)
	(decrease score by $Score)
	(clear all pronouns)
	(update environment around player)
	(fail)

#dont-go-north
(test *)
(run *)
	(current player $Player)
	($Player is #in #foyer)
	(perform [go #north])
	($Player is #in #foyer)

